          <div class="frosted_background inblog_featured_blog">
            <div class="featured_image">
              <img src="{{ post.data.showcase_image }}" alt="{{ post.data.title }}" class="blog_snippet__image">
            </div>
            <div class="snippet__content">
              <h3 class="blog_snippet_title"><a href="{{post.url}}" >{{post.data.title }}</a></h3>
              <p  class="blog_snippet_meta">by <span>{{ post.data.author }}</span> on <span>{{ post.data.date | postDate }}</span></p>
              <p class="content_type">Type: <b class="type">{{ post.data.type}}</b></p>
              <p class="blog_snippet_body">{{ post.data.description }}</p>
            </div>
          </div>