        <div class="frosted_background frosted_texture blog_snippet">
          <div class="snippet__content">
            <h2 class="blog_snippet_title"><a href="{{post.url}}" >{{post.data.title }}</a></h2>
            <p class="blog_snippet_meta">by <span>{{ post.data.author }}</span> on <span>{{ post.data.date | postDate }}</span></p>
            <p class="blog_snippet_body">{{ post.data.description }}</p>
            <a href="{{ post.url }}" class="button frosted_background frosted_texture">Continue Reading</a>
          </div>
          <div class="snippet_image">
            <img src="{{ post.data.featured_image }}" alt="{{ post.data.title }}" class="blog_snippet__image">
          </div>
        </div>