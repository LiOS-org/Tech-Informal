---
layout: base.njk
---     
<article data-pagefind-body class="main-article frosted_background frosted_texture">
  <div class="container container--narrow flow">
  
      <h1 class="article-title">
        {{title}}
      </h1>
      <figure class="main-article_figure">
        <img src="{{featured_image}}" alt="{{ imageAlt}}">
      </figure>
    {{content | safe}}
    
    <!-- Like/Dislike Section -->
    <div class="reactions-section">
      <div class="reactions-container">
        <button id="like-btn" class="reaction-btn like-btn" title="Like this article">
          <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M14 9V5a3 3 0 0 0-3-3l-4 9v11h11.28a2 2 0 0 0 2-1.7l1.38-9a2 2 0 0 0-2-2.3zM7 22H4a2 2 0 0 1-2-2v-7a2 2 0 0 1 2-2h3"/>
          </svg>
          <span id="like-count">0</span>
        </button>
        
        <button id="dislike-btn" class="reaction-btn dislike-btn" title="Dislike this article">
          <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M10 15v4a3 3 0 0 0 3 3l4-9V2H5.72a2 2 0 0 0-2 1.7l-1.38 9a2 2 0 0 0 2 2.3zm7-13h2.67A2.31 2.31 0 0 1 22 4v7a2.31 2.31 0 0 1-2.33 2H17"/>
          </svg>
          <span id="dislike-count">0</span>
        </button>
      </div>
    </div>
    
  <script src="https://giscus.app/client.js"
        data-repo="LiOS-org/Tech-Informal"
        data-repo-id="R_kgDOO2iCJA"
        data-category="Announcements"
        data-category-id="DIC_kwDOO2iCJM4CrGTw"
        data-mapping="pathname"
        data-strict="0"
        data-reactions-enabled="1"
        data-emit-metadata="0"
        data-input-position="top"
        data-theme="transparent_dark"
        data-lang="en"
        data-loading="lazy"
        crossorigin="anonymous"
        async>
</script>
  </div>
</article>
